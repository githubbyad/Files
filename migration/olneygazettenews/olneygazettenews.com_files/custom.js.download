//BEGIN: SubMenu Footer Limit

$(window).bind('load',function(){
$('.SubMenus81').css('height', 'auto');
$('.SubMenus81').each(function () {
  if ($(this).height() > 147) {
    $(this).siblings('.SeeMore81').css('display', 'block');
  } 
  else {
    $(this).siblings('.SeeMore81').css('display', 'none');
  }
});
$('.SubMenus81').css('height', '147px');
$('.SeeMore81').click(function () {
  $(this).siblings('.SubMenus81').css('height', 'auto');
  $(this).css('display', 'none');
});
});

//END: SubMenu Footer Limit


