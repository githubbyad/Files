// BEGIN: Read Cookie

$(document).ready(function () {
setInterval(function(){
if (readCookie('loginStatus') != 'Yes') {
$('.LOGIN').css('display', 'block');
$('.LOGOUT').css('display', 'none');
} 
else {
$('.LOGIN').css('display', 'none');
$('.LOGOUT').css('display', 'block');
}
}, 10); 
});

