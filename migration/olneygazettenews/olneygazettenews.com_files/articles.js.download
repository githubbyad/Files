 function GetHighlights6(){document.write('<div id="Highlight6" style="display: none;"><div id="sliderh6_container" class="slider_container_h6"><div u="slides" class="slides_h6"><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">MAR</div><div id="date_H6">28</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index165.htm"  class="archive_menu_text_H6">165</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/barbara-j-beck,-83-p507-165.htm">Barbara J. Beck, 83</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">MAR</div><div id="date_H6">17</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index90.htm"  class="archive_menu_text_H6">Front Page</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/carle-health-names-knight-chief-medical-officer-p504-90.htm">Carle Health names Knight chief medical officer</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">JUN</div><div id="date_H6">11</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index165.htm"  class="archive_menu_text_H6">165</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/john-william-‘bill’-schwartz,-81-p473-165.htm">John William ‘Bill’ Schwartz, 81</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">JAN</div><div id="date_H6">30</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index165.htm"  class="archive_menu_text_H6">165</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/nadine-l-martin,-83-p468-165.htm">Nadine L. Martin, 83</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">DEC</div><div id="date_H6">10</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index164.htm"  class="archive_menu_text_H6">LOCAL NEWS</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/council-crawls-over-finish-line,-approves-golf-carts-and-utvs-on-city-stree-p462-164.htm">Council crawls over finish line, approves golf carts and UTVs on city streets on 3-2 vote</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">DEC</div><div id="date_H6">10</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index90.htm"  class="archive_menu_text_H6">Front Page</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/southeastern-il-friends-of-nra-4th-annual-banquet-p466-90.htm">Southeastern Il Friends Of NRA 4th Annual Banquet</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">DEC</div><div id="date_H6">10</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index165.htm"  class="archive_menu_text_H6">165</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/raymond-f-henry-jr-,-84-p464-165.htm">Raymond F. Henry Jr., 84</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">DEC</div><div id="date_H6">10</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index164.htm"  class="archive_menu_text_H6">LOCAL NEWS</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/vfw-presents-initial-plans-for-memorial,-council-members-suggest-alternate--p461-164.htm">VFW presents initial plans for memorial, council members suggest alternate locations</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">DEC</div><div id="date_H6">10</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index164.htm"  class="archive_menu_text_H6">LOCAL NEWS</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/council-taps-plan-commission-to-consider-cannabis-zoning-p460-164.htm">Council taps Plan Commission to consider cannabis zoning</a></div> </div></div><div class="singleslide-bg_h6"> <div u="thumb"><div class="pageissuedate layout_pageissuedate"><div id="times_H6"><div id="month_H6">NOV</div><div id="date_H6">21</div></div></div><div id="submenu_H6"><a href="https://olneygazettenews.com/index165.htm"  class="archive_menu_text_H6">165</a></div>  <div class="text-thumb_h6"><a href="https://olneygazettenews.com/rita-e-cannon,-58-p456-165.htm">Rita E. Cannon, 58</a></div> </div></div></div><span u="arrowleft" class="jssora15ll_h6 jssora15l_h6" style=""></span><span u="arrowright" class="jssora15rr_h6 jssora15r_h6" style=""></span><div u="thumbnavigator" class="jssort04_h6 thumb_cont_h6" style=""><div u="slides" style="Top: 2px; left: 0px;"><div u="prototype" class="pp_h6 p_h6"><div class="w_h6"><div u="thumbnailtemplate" style="width: 100%; height: 100%; border: none; position: absolute; top: 0; left:0;"></div><div id="bluestrip_h6"></div></div><div class="c_h6" style="position: absolute; background-color: #000; top: 0; left:0;"></div></div></div></div></div></div>');DisplayHighlight('Highlight6');}

 function GetHighlights8(){document.write('<div id="Highlight8" style="display:none";><div id="highlight8_container" class="slider_container_H8b"><div u="loading" style="position: absolute; top: 0px; left: 0px;"><div style="filter: alpha(opacity=70); opacity: 0.7; position: absolute; display: block; top: 0px; left: 0px; width: 100%; height: 100%;"></div><div style="position: absolute; display: block; background: url(/lib/JQuery/Highlight8/loading.gif) no-repeat center #222222; top: 0px; left: 0px; width: 100%; height: 100%;"></div></div><div u="slides" class="slides_H8b"><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">MAR</div><div id="date_H8b">28</div></div></div><a href="https://olneygazettenews.com/barbara-j-beck,-83-p507-165.htm"><span class="heading_H8b" style="display: block;">Barbara J. Beck, 83</span></a><div class="body_content_H8b">Barbara J. Beck, 83, of Sturgeon Bay, Wis., passed away early Monday, March 20, 2023, at Door County Medical Center.\nBarbara was born October 10, 1939, in Olney, the daughter of the late (Gould) Weber and Evelyn Jane (Greathouse) Murvin. Barbara graduated from West Richland High School before entering Northwestern University, graduating from Dental Hygiene School.\nOn September 23, 1962, she married John Jay Beck in Olney. Barb continued to work as a dental hygienist until the birth of her first of four children in 1964. She would devote her life to her family, instilling in her children her love of adventure and food. Barb was a great driver, and at a moment’s notice gathered the children and headed out for learning adventures and sights to see with a mission to expose them to the world outside Door County. She loved to read novels, and was an accomplished and learned cook, deciphering recipes and cookbooks, leaving many notes and observations throughout the margins, serving as a lasting tribute to her culinary interests and devotion to cooking for her family. Her collection of 19 sewing machines was a complement to her sewing interests, creative talents, and mechanical abilities as she was able to fix those machines when needed.\nSurviving family include her devoted husband, Dr. John Beck, of Sturgeon Bay, Wis.; four loving children, John (Elizabeth) Beck, of Appleton, Wis., Dan (Rose) Beck, of Algoma, Wis., Laura Beck, of Madison, Wis., and Martha Delancey, of Green Bay, Wis.; six precious grandchildren, John Howard Beck, Jeremy Badgley Beck, Oliver Caspian Delancey, Edmund Nikolas Delancey, Amy Sue Beck, and Chad Roland Beck; brother, Roger Murvin, of the Villages, Fla.; and sister, Margaret (Dan) Shimkos, of Okemos, Mich.\nPreceding her in death were her parents, brother, Stephen Murvin, and sister-in-law, Mary Murvin.\nPrivate family burial will be held in Bayside Cemetery, Sturgeon Bay, Wis. A celebration of her life and gathering will be held from noon-3 p.m. Thursday, April 6 at The Lodge at Leathem Smith, 1640 Memorial Dr., Sturgeon Bay, WI 54235.\n“Our mother was everything to us, from the daily fresh baked sour dough bread and sewing our clothes to giving us a solid foundation of family life and exposing us to the world we would live in. The love she and our dad had for each other was powerful and was evident as she supported him and his devotion to the community he served. She was a great example for all who knew her and we will miss her deeply.”\nHuehns Funeral Home, Inc. in Sturgeon Bay, Wis. is assisting the Beck family. Expressions of sympathy, memories, and photos of Barbara may be shared with her family through her tribute page at www.huehnsfuneralhome.com.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/barbara-j-beck,-83-p507-165.htm"><img u="image" src="https://olneygazettenews.com/28-03-2023-03-30-46-pm-7807573.jpg" alt="Barbara J. Beck, 83" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/28-03-2023-03-30-46-pm-7807573.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">MAR</div><div id="date_H8b">17</div></div></div><a href="https://olneygazettenews.com/carle-health-names-knight-chief-medical-officer-p504-90.htm"><span class="heading_H8b" style="display: block;">Carle Health names Knight chief medical officer</span></a><div class="body_content_H8b">Carle Health announced Napoleon Knight, MD, as its new chief medical officer.\nKnight has more than 30 years of experience as an Emergency Medicine physician and other leadership roles as he steers Carle’s efforts to empower all clinicians to provide high-quality outcomes for patients. He most recently held the role of medical director of the Carle southern region Emergency Department, and also led as vice president of Medical Affairs, medical director of the Rural Alliance, and several other positions in the health-care system.\nDr. Knight has extensive understanding of the needs of the patient population and the challenges of the evolving medical industry. He excels at bringing innovation and collaboration to the forefront to help create timely solutions.\nIn his many leadership roles in the Carle Health system, he worked to implement strategies to improve the health of the diverse service population, extend specialty care available in the system, increase health-plan membership, and made lasting impact to advancing the quality standards of the organization. He also serves as a clinical associate professor at the first-of-its-kind Carle Illinois College of Medicine.\nAs an involved member of the medical community, he spent time as the American Association for Physician Leadership Board chairman, and is a board member of the Illinois College of Emergency Physicians.\nKnight earned a bachelor’s degree from the University of Colorado, Boulder, Colo., medical degree from the University of Minnesota, Minneapolis, completed an Emergency Medicine Residency, Denver General Affiliated Program in Emergency Medicine, and an MBA, University of Massachusetts, Amherst, Mass.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/carle-health-names-knight-chief-medical-officer-p504-90.htm"><img u="image" src="https://olneygazettenews.com/24-03-2022-02-05-02-pm-1508068.jpg" alt="Carle Health names Knight chief medical officer" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/24-03-2022-02-05-02-pm-1508068.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">JUN</div><div id="date_H8b">11</div></div></div><a href="https://olneygazettenews.com/john-william-‘bill’-schwartz,-81-p473-165.htm"><span class="heading_H8b" style="display: block;">John William ‘Bill’ Schwartz, 81</span></a><div class="body_content_H8b">John William “Bill” Schwartz, 81, of Olney, passed away Friday, June 5, 2020, at his home with his loving family and beloved pet Little John Pepper at his side.\nGraveside services with full military rites will be held at 10:30 a.m. Friday, June 12 in Dundas Cemetery with Father Bill Rowe officiating. Glasser Funeral Home in Bridgeport in charge of arrrangements. Online condolences may be left at www.glasserfh.com.\nBill was born March 23, 1939, in Noble, the son of Minerva Luvicia  (Robinson) and Everett Harold Schwartz. He married the love of his life Rose Ann (Fuller) on July 26, 1963, in the Blessed Sacrament Church in Hollywood, Calif. She survives.\nBill served his country in the United States Navy during the Vietnam War on the USS Buck, and was awarded the Vietnam Expedition Medal as well as others.\nBill retired from the GTE phone company in 1991 after 25 years of service. He enjoyed traveling the U.S. and Canada in his Airstreams, and loved to do woodworking in the shop he built with his sons, remodel houses, and collect and repair old clocks.\nBill is survived by his wife, Rose Ann; sons, Andrew Everett Schwartz, of Fairview Heights, Robert Christopher Schwartz and wife Wendy, of Brownsburg, Ind., and Timothy Scott Schwartz, of Clearwater, Fla.; one sister, Mabel Eileen Linson and husband Ken, of Rutland; two brothers, Galen Edward Schwartz and wife Pamela, of Olney, and Glen Eugene Schwartz, of Horseshoe Bend, Ark.; grandchildren, Nicholas, Branden, Sean, Andriea, McKenzie and Jackson Schwartz; and great-grandchildren, Addison, Colton and Avalynn Schwartz.\nHe was preceded in death by his parents, one sister, Betty Louise and three brothers, Larry Lee Schwartz, Kenneth Dean Schwartz, and Everett Junior Schwartz.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/john-william-‘bill’-schwartz,-81-p473-165.htm"><img u="image" src="https://olneygazettenews.com/6-11-2020-5-17-57-PM-9653374.jpg" alt="John William ‘Bill’ Schwartz, 81" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/6-11-2020-5-17-57-PM-9653374.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">JAN</div><div id="date_H8b">30</div></div></div><a href="https://olneygazettenews.com/nadine-l-martin,-83-p468-165.htm"><span class="heading_H8b" style="display: block;">Nadine L. Martin, 83</span></a><div class="body_content_H8b">Nadine L. Martin, 83, of Olney, passed away at 6:02 p.m. Saturday, January 25, 2020, at Aperion Care in Olney.\nFuneral services celebrating Nadine’s life were held at 1 p.m. Wednesday, January 29 at Meyer Funeral Home in Newton with Father Brett Judkins officiating. Private burial was in Mt. Calvary Cemetery in Newton.\nNadine was born March 27, 1936, in rural Olney, the daughter of Peter J. and Adelphia S. (Schneider) Weiler. She married Edward E. Martin Sr. on August 28, 1959, in Effingham. He preceded her in death on October 23, 1965.\nNadine was a homemaker and was a child caregiver for many years. She was a member of St. Joseph Catholic Church in Olney, and the Loyal Order of Moose in Olney. \nNadine loved sewing, quilt designing, cooking, drawing, reading, and listening to country music. \nNadine is survived by her sons, Edward Martin Jr. (Jeanine Fell), of Newton, Lori Zimmerle (Mike), of Olney, Helen (John) Rich, of Newton, and Phil (Rachel) Martin, of Mt. Carmel; nine grandchildren, Talina (Daniel) Spurling, Luke Zimmerle, Timothy (Erin) Felty, Adam (Bobbie) Felty, Haley (Daniel) Gray, Breeanne Rich, Hannah Martin, Sarah Martin, and Noah Martin; seven great-grandchildren, Michael Felty, Gabe Felty, Mason Felty, Chase Felty, Ellie Felty, Maverick Felty, and Ryleigh Gray; brother, Dennis Weiler, of West Liberty; and sister, Shirley Bailey, of Dundas.\nShe was preceded in death by her parents, and a sister, Geraldine Craig.\nIn loving memory of Nadine, memorials may be made to IECC Nursing Program, c/o IECC, 233 E. Chestnut St., Olney, IL 62450.\nThe obituary may be viewed and condolences left at www.meyerfh.com.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/nadine-l-martin,-83-p468-165.htm"><img u="image" src="https://olneygazettenews.com/1-31-2020-3-36-05-PM-4790856.jpg" alt="Nadine L. Martin, 83" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/1-31-2020-3-36-05-PM-4790856.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">DEC</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/council-crawls-over-finish-line,-approves-golf-carts-and-utvs-on-city-stree-p462-164.htm"><span class="heading_H8b" style="display: block;">Council crawls over finish line, approves golf carts and UTVs on city streets on 3-2 vote</span></a><div class="body_content_H8b">Mark Allen\nEditor\nOlney City Council approved street use of golf carts and UTVs at its meeting Nov. 25 on a 3-2 vote.\nMirroring the multi-meeting debate on the issue, the council navigated a surreal landscape paved with (at least) two page twos and five page fives, including one erroneous copy that mischievously tagged along.\nCity Attorney Bart Zuber gave the council multiple options, including for carts, UTVs, and both.\nCouncilwoman Belinda Henton said someone asked her how many times cars were inspected before a licenses are issued. If a cart or UTV passed an initial inspection, it would probably be the same the following year, she said, and police could issue citations if not.\nOne-time inspections would not impose as much burden on police, Henton said. “It’s time they can meet an officer in a good way,” she said, adding that officers were posted at basketball games for visibility.\nMayor Mark Lambird asked who would do the inspections.\nHenton said police could perform the 10-15 inspections she expected, eliminating the extra fee and a burden on local businesses.\nCouncilman John McLaughlin said he was fine either way.\nLambird said he could see the benefit of inspections by certified professionals, but the council could revisit the issue if 200 people apply.\n“I don’t feel like we need to add more for the chief to do and his staff. I think they’re at their limit,” said Councilwoman Morgan Fehrenbacher.\nLambird asked how often the police department had someone there who could readily perform an inspection.\n“I dunno. We can do them. Whatever,” said Police Chief Kevin Paddock.\nLambird asked at what point it would be a burden due to not having officers at the station.\nPaddock said they would probably have to set up an appointment schedule. “We ran all day today.”\nCouncilman Greg Eyer quoted an insurance agent that the ordinance had a potential for serious accidents if not properly enforced.\nThe ordinance identified busy streets that alternative vehicles would be required to traverse, Eyer said, putting them in their most vulnerable position with no side-impact protection, airbags, or door. “Simple physics, recipe of disaster should collisions occur, brought into being opportunity for injury or death that did not exist before now,” he said.\nIf the ordinance passed, “remember your ‘yes’ vote when you first hear of an accident involving a cart on the streets of Olney,” Eyer said.\nLambird asked for a consensus on inspections.\nMcLaughlin said he would feel better if the police department performed them because they knew what needed to be checked. It would be easier for a private business not to care as much, he said.\n“I don’t wanna say I don’t care either way, but I’m fine either way,” McLaughlin said.\nAn audience member said his concern was streets in the Taylor and Doenges subdivisions would be blocked in by Hall and East streets. “We cannot get out.”\nMcLaughlin said they could drive on Hall but had to turn at the next road.\nLambird said the intent was for people to cross to the nearest road.\nAudience Member said all streets were terrible at certain times of day, but other times there was no traffic.\nLambird said the greater danger was when traffic is light and someone drives 45 miles per hour.\nHenton suggested prohibiting use on Van and Hall during school-bus hours.\nLambird said the simpler, the better.\nFehrenbacher said if it got too complex, people wouldn’t know the rules.\nLambird said they would use the page with the police inspections.\n“The fifth page five,” Fehrenbacher said.\nLambird said they needed a page two as well.\n“I think there’s an extra page five in there that’s only distinguished by a spacing error,” Zuber said. “There should be only four page fives.”\nLambird said they were adding “at nearest intersection. And which page five are we talking about? The third one?”\n“No, the fifth one,” Fehrenbacher said.\n“It is substantively the same as the second page five,” Zuber said.\nLambird stated the wording for inspections as chief of police or designated representatives, and permit renewal by presenting previous inspection.\nEyer said they were making decisions before it was passed.\nLambird said all input was welcome, and asked if Eyer planned to vote yes for the ordinance.\n“No. I’ve made my peace,” Eyer said.\nAn audience member said his moped could drive 20 on the highway with no sides.\nEyer said that was more maneuverable.\nAudience member Morgan Henton said a cart was more visible.\n“Remember when you hear of an accident it all could have been avoided,” Eyer said.\nMcLaughlin said anything the city could do, including building a playground, splash park or swimming pool, offered the potential for someone to get hurt. People who drive carts make a decision, he said.\n“They also have to take some responsibility for themselves to make that decision,” McLaughlin said, adding there is inherent risk in everything.\nLambird said that a century ago, city officials were having the same discussion about allowing cars on the roads.\nEyer said automobiles and trucks were made for roadways, and golf carts were made for golf courses. The average vehicle sold was a 4,200-pound F150, he said.\nHenton said she kept thinking of motorcycles.\nEyer said those were more maneuverable.\nHenton asked if they could make Van and Hall similar to “when children are present” in school zones.\n“We can put anything in an ordinance that you want to put in,” Zuber said, but it would come down to the common sense and judgment of an officer at the scene at the time.\nLambird asked what Henton wanted to vote on.\n“When children are present,” Henton said\n“That seems subjective,” Lambird said.\n“How’s that?” Henton asked.\nLambird asked about children present in the middle of the summer.\nPaddock said it applied from 7:30 a.m.-4 p.m. on school days. When kids were in the building, the speed limit was 30, he said.\nLambird said it applied when children were coming or reasonably believed to be leaving.\nHenton said she would like Van and Hall to be the same as a school zone.\n“I’m not in favor of that,” Fehrenbacher said.\nLambird said they would vote on the changes, then vote on the whole. Yes votes for each page would approve only the change to the ordinance, not the ordinance itself, he said.\nMembers unanimously approved having vehicles certified by the city, and proscribing use on several roads except to travel to the nearest intersection.\nHenton asked about making Van and Hall school zones.\nThey were getting into something subjective that would cause issues for officers to figure out how to make it work, Lambird said.\n“I’m just telling you you’re making it a nightmare for us,” Paddock said.\nZuber said they could make a timeframe exception to the prohibition.\n“Generally brevity is the best option,” Lambird said.\nThe council approved keeping Hall and Van on the list of prohibited streets on a 3-2 vote. Lambird, Eyer, and Fehrenbacher voted yes; Henton and McLaughlin voted no.\nThe council approved having inspections done by the chief of police or designated representatives on 4-1 vote with Fehrenbacher voting no.\nLambird asked when the ordinance would take effect.\nZuber said it would be effective when it passed, but no one could get a permit until decals and signage arrived.\nPaddock asked if the ordinance allowed only carts or UTVs.\nLambird said it would allow both.\nEyer asked if they determined how much signage was required.\nHenton said IDOT did not have specific rules, but stated signage was required.\nLambird said they could post it at the town’s entrances.\nPaddock noted there were places in town that did not allow parking but lacked no-parking signs.\nThe ordinance passed 3-2 with Lambird, Henton, and McLaughlin voting yes; Eyer and Fehrenbacher voted no.\n“Motion passes. And thank you for all of that,” Lambird said.\n(Votes unanimous unless indicated. Council members include Mayor Mark Lambird, Greg Eyer, Morgan Fehrenbacher, Belinda Henton, and John McLaughlin.)</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/council-crawls-over-finish-line,-approves-golf-carts-and-utvs-on-city-stree-p462-164.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="Council crawls over finish line, approves golf carts and UTVs on city streets on 3-2 vote" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">DEC</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/southeastern-il-friends-of-nra-4th-annual-banquet-p466-90.htm"><span class="heading_H8b" style="display: block;">Southeastern Il Friends Of NRA 4th Annual Banquet</span></a><div class="body_content_H8b">Save the Date\nSoutheastern Il Friends Of NRA 4th Annual Banquet\nMarch 12th, 2020 at The Holiday in Olney, IL\nDoors open at 5:00 p.m.\nLive Auction, Silent Auction and Games\nBlue Bucket Firearm Drawings\nWhite Bucket Drawings\nRed Bucket Firearm Drawings\n\nFriends of NRA is a 501 (C) (3) Charitable Organization\nContact information\nJeff Fleming (618)395-8491\nJohn White (618)354-1047\nGet your tickets now or reserve your table!</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/southeastern-il-friends-of-nra-4th-annual-banquet-p466-90.htm"><img u="image" src="https://olneygazettenews.com/1-9-2020-11-21-26-AM-5459802.jpg" alt="Southeastern Il Friends Of NRA 4th Annual Banquet" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/1-9-2020-11-21-26-AM-5459802.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">DEC</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/raymond-f-henry-jr-,-84-p464-165.htm"><span class="heading_H8b" style="display: block;">Raymond F. Henry Jr., 84</span></a><div class="body_content_H8b">Raymond F. Henry Jr., 84\nRaymond F. Henry Jr., 84, of Olney, died Saturday, December 7, 2019, at Helia Healthcare in Olney.\nFuneral services will be held at 11 a.m. Tuesday, Dec. 17 at Kistler-Patterson Funeral Home in Olney. Visitation will be at 10 a.m. Burial with full military rites will follow in Haven Hill Memorial Gardens.\nRaymond was born December 27, 1934, in Washington, D.C., the son of Raymond F. Sr. and Bessie (Farris) Henry. He married Doris (Munger) on September 1, 1963, in Noble. She survives.\nRaymond served in the U.S. Army from 1955-1987, and spent time in Korea from 1956-1958. He served in several different units in the Army National Guard, rising to the rank of Command Sergeant Major before retiring. Ray worked for GTE in the computer division for 36 years. He was a member of American Legion and Immanuel United Methodist Church. Raymond also wrote a book, “Memories of a Citizen Soldier.”\nRaymond is survived by his wife, Doris Henry; son, Rodger F. Henry and wife Peggy, of Great Lakes; son, Todd E. Henry and wife Christi, of Kansas City, Kan.; and grandchildren, Ryan Farris Henry and Abigail Rose Henry.\nHe was preceded in death by his parents, two brothers, and a sister.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/raymond-f-henry-jr-,-84-p464-165.htm"><img u="image" src="https://olneygazettenews.com/12-13-2019-9-40-36-AM-3900201.jpg" alt="Raymond F. Henry Jr., 84" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/12-13-2019-9-40-36-AM-3900201.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">DEC</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/vfw-presents-initial-plans-for-memorial,-council-members-suggest-alternate--p461-164.htm"><span class="heading_H8b" style="display: block;">VFW presents initial plans for memorial, council members suggest alternate locations</span></a><div class="body_content_H8b">Mark Allen\nEditor\nOlney City Council heard a presentation on a proposed veterans memorial at its meeting Nov. 25 and attempted to steer proponents away from their preferred location.\nVeterans of Foreign Wars Commander Ryan Higginbotham presented a rough sketch of a Richland County Veterans Memorial, north of the drive at the west entrance to Olney City Park. The area would eliminate the “dilapidated fountain,” he said, and include branch flags, donor bricks, and a list of local soldiers who were killed in action.\n“This is actually for them more than anything,” Higginbotham said of KIAs.\nThey discussed completing the memorial by Veterans Day 2020, but realized Memorial Day 2021 was more realistic. “We do not wanna rush this. We want it done right,” Higginbotham said.\nCouncilman John McLaughlin asked if City Manager Allen Barker had any concerns.\nBarker said they had some preliminary discussions about prevailing wage.\nThe area would be leased to the VFW until completed, then leased back to the city.\nCouncilwoman Morgan Fehrenbacher said there were several large trees in that area of the park.\nHigginbotham said there were three big trees in the middle, one of them diseased, and another with a dead top. A few trees on the edges might stay, he said, adding that they would need the space and didn’t want the memorial covered in leaves.\nVFW Quartermaster Robert Ritter said they also didn’t want roots coming up through the memorial.\nIt would include a new water feature, and branch service songs would play at the tops of hours, Higginbotham said.\n“We would like for people outside the community to come in and see this and see what we’ve done,” he said of the location right off Ill. 130.\n“Our goal is to represent every Richland County veteran at no cost to them,” Ritter said.\nFehrenbacher asked if no decision could be made until they resolve the issue of prevailing wage.\nCity Attorney Bart Zuber said that was correct.\nCouncilwoman Belinda Henton said the city would be responsible for maintenance.\nHigginbotham said they planned to establish a foundation for repairs, “not just build it and say, ‘Here you go, Olney, it’s up to you.’”\nThe memorial committee included five VFW members, Higginbotham said, and they planned to add four community members.\nRitter said there were people willing to donate labor, which could not be donated to the city.\nHenton said the proposed area included five mature oaks. “Do you have any idea how long it takes an oak tree to bear acorns?” she asked.\nHigginbotham asked how long.\nHenton said 20-30 years.\nHigginbotham said they would be more than happy to replace trees.\n“How big? Twenty years old?” Henton asked.\nHigginbotham said no, but they would be willing to do something for Arbor Day.\nHenton said the value of those trees couldn’t be replaced.\n“The value of our veterans is higher than the value of a tree,” McLaughlin said.\nRitter said the area was not struggling for trees or food for wildlife.\nHenton said there were already several memorials, including big ones at the courthouse.\nHigginbotham said that if you blinked, you wouldn’t know the courthouse memorials were there.\nHenton said the proposed memorial was at ground level.\nHigginbotham said it included a 12-foot memorial.\nHenton asked if they considered someplace in Musgrove Park.\nThey said that park was saved for sports. “In my view, that’s for the children,” Ritter said, adding that not many people drive by Musgrove.\nHenton asked if they had seen the park during baseball tournaments, adding that Mack Avenue and East Street were major thoroughfares. “And there’s no trees. That’s my point.”\nFehrenbacher said prevailing wage remained an issue.\nRitter said the preferred location was about a half acre.\nHenton asked if the white-squirrel memorial would be removed.\nHigginbotham said it would be relocated, and Ritter said the front of the Fair Board building would be a good location.\nCouncilman Greg Eyer said he absolutely supported and applauded the memorial, adding that he was a veteran. “Site selection I do question also,” he said.\nTrees could be replaced, but his grandchildren wouldn’t be able to enjoy trees that big. They might have some issues but seemed to be in fair condition, Eyer said.\nThat area of the park was used a lot by people stopping to eat lunch, he said, enjoying the shade and easy access.\nThe fountain was dilapidated but had been operating recently. “For children of Olney, we’ve grown up with that,” Eyer said. “We’d make our parents go out of the way to see that fountain.”\nOlney City Park and Musgrove Park each had 50 acres, he said, and there might be other sites that would not require destroying a developed, landscaped, and utilized area.\nEyer asked if they would consider any other areas.\n“We would have to discuss that,” Higginbotham said.\nMcLaughlin said he had no problem with the proposed area and hardly even saw anyone there.\nEyer asked if the city had plans for the location of the Musgrove house.\nMayor Mark Lambird said a picnic area was the idea.\n“That’d be pretty hidden from any roadways,” Ritter said.\nLambird said that area had several trees, but the maples were prone to blowing over, and most oaks would probably die within 10 years due to disease.\nRitter said the fountain needed to be dug up and repaired because the base was leaking.\nBarker said he had not heard that but confirmed its condition. “It is in pretty bad lookin’ shape right now.”\nLambird said they needed to research how they could proceed regardless of location. “So I reckon we’ll see you folks again at the December-January meeting.”\nFehrenbacher suggested looking at other options.\nHigginbotham said they could and would.\nRitter said other places they considered were privately owned, which would cause problems. The college’s land adjacent to the highway would be ideal, he said, but he didn’t know how hard it would be to get them to allow it.\n“They have an oil derrick,” Henton said. She said northern Musgrove Park had the skateboard park and children’s memorial, plus a parking lot and playground, which would attract visitors.\nEyer said the southwest corner was leveled for a field that never materialized.\n“It’s been used as a soccer field,” McLaughlin said.\nRitter said they wanted a location that already had utilities.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/vfw-presents-initial-plans-for-memorial,-council-members-suggest-alternate--p461-164.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="VFW presents initial plans for memorial, council members suggest alternate locations" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">DEC</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/council-taps-plan-commission-to-consider-cannabis-zoning-p460-164.htm"><span class="heading_H8b" style="display: block;">Council taps Plan Commission to consider cannabis zoning</span></a><div class="body_content_H8b">Mark Allen\nEditor\nThe city’s Plan Commission will consider zoning rules pertaining to adult-use cannabis facilities, Olney City Council decided at its meeting Nov. 12.\nCity Manager Allen Barker said zoning regulations did not include cannabis, and if it were to be sold, the city needed proper zoning. The Plan Commission would hold a public hearing, he said.\nCity Attorney Bart Zuber said the council previously decided that if sales were allowed, the city would apply the maximum tax rate allowed by the state. He said the council now had to decide whether to allow sales.\nThe state did not allow prohibiting sale of medical cannabis, but the city could prohibit recreational sales or regulate the time, place of manner of sales, including zoning districts, Zuber said.\nHe said probable zones for cannabis sales included C-1 Neighborhood Shopping District, C-2 Commercial District, C-3 Central Business District, C-4 Planned Commercial District, M-1 Light Industrial District, and M-2 Heavy Industrial District.\nThe state designated six types of cannabis businesses, Zuber said, including dispensaries, cultivation centers, and transporters. A transporter might located in M-1, and a dispensary in C-1 or C-3, he said, which the commission would address with a public hearing.\nZuber tweaked the model ordinance to be compatible with city code.\nCity Clerk Kelsie Sterchi said the hearing needed to be set by noon the next day, and all the council needed that night was a resolution to call a public hearing. The commission could make a recommendation on prohibition or where to allow sales, she said.\nCouncilman Greg Eyer asked if it were a matter of decorum for the Plan Commission to hold a hearing. “My thought, I am not for this, not for sale of recreational cannabis use in Olney.”\nIf other members were also in opposition, there was no reason to forward the issue to the commission, he said.\nMayor Mark Lambird noted the council just finished a lengthy discussion of the need for additional tax revenue to improve roads. “I think we would be remiss to think we can stand here and hold back the ocean. It’s coming. People are going to be buying marijuana in Olney, and they’re going to smoke it,” he said.\n“I would prefer they buy it here, and I would prefer every community in the area banned it,” Lambird said.\nEyer questioned whether legal sales would be cheaper than what people get from dealers.\n“I don’t think anyone knows,” said Police Chief Kevin Paddock.\nLambird said he talked with a Colorado town, approximately Olney’s size, near the New Mexico border. “The amount of tax revenue they’re were generated was gigantic,” he said, about $3 million a year.\nWhile Olney’s experience might differ, Lambird said, “The morality of it is, if you don’t like it, don’t do it. We can’t stop them. We need jobs, we need revenue.”\nCouncilwoman Morgan Fehrenbacher said nothing would stop such businesses from locating inside the county, so the city could miss the tax dollars and still have nearby cannabis sales.\nLambird said communities that opt out would be allowing it in five to 10 years. “That’s just the way it’s going to work. It’s coming.”\nOnly two dispensaries would be allowed in the region in the first round, Lambird said, so while Olney’s chances were not great, they were improving daily when other communities opted out.\nCouncilman John McLaughlin said he didn’t mind the commission holding a hearing and preparing recommendations. “I’m more leaning on the ‘no’ side like Greg. We’ll see.”</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/council-taps-plan-commission-to-consider-cannabis-zoning-p460-164.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="Council taps Plan Commission to consider cannabis zoning" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">NOV</div><div id="date_H8b">21</div></div></div><a href="https://olneygazettenews.com/rita-e-cannon,-58-p456-165.htm"><span class="heading_H8b" style="display: block;">Rita E. Cannon, 58</span></a><div class="body_content_H8b">Rita E. Cannon, 58, of Olney, died Monday, December 2, 2019, at Deaconess Midtown Hospital in Evansville, Ind.\nFuneral services will be held at 11 a.m. Friday, December 6 at Kistler-Patterson Funeral Home in Olney. Visitation will be at 10 a.m. Burial will follow in Crest Haven Memorial Park in rural Claremont.\nRita was born October 24, 1961, in Olney, the daughter of Roy “Gene” and Wanda (Harris) Miller.\nRita is survived by her twin sons, Kenneth Cannon, of Olney, and Matthew Cannon, of Bible Grove; brother, Stephen E. Miller and wife Connie, of Marshall; and sister, Janet Newkirk, of Olney.\nShe was preceded in death by her parents, Gene and Wanda Miller.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/rita-e-cannon,-58-p456-165.htm"><img u="image" src="https://olneygazettenews.com/12-5-2019-11-34-47-AM-8102624.jpg" alt="Rita E. Cannon, 58" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/12-5-2019-11-34-47-AM-8102624.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">NOV</div><div id="date_H8b">21</div></div></div><a href="https://olneygazettenews.com/veterans-of-foreign-wars-presents-a-donation-of-$500-to-olney-valor-quilter-p453-90.htm"><span class="heading_H8b" style="display: block;">Veterans of Foreign Wars presents a donation of $500 to Olney Valor Quilters.</span></a><div class="body_content_H8b">Veterans of Foreign Wars presents a donation of $500 to Olney Valor Quilters. The group appreciates the VFW for allowing the bake sale and 50/50 raffle at the monthly taco night. The event was very well attended, and funds raised will go toward future Quilt of Valor quilts. Since 2015, the Olney Valor Quilters have awarded 270 quilts. The group’s mission is to honor service members and veterans who have been touched by war. The Quilts of Valor presentation during taco night was planned for many months as a surprise to the six veterans who were honored. photo submitted</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/veterans-of-foreign-wars-presents-a-donation-of-$500-to-olney-valor-quilter-p453-90.htm"><img u="image" src="https://olneygazettenews.com/11-21-2019-1-46-32-PM-9160058.jpg" alt="Veterans of Foreign Wars presents a donation of $500 to Olney Valor Quilters." class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/11-21-2019-1-46-32-PM-9160058.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">NOV</div><div id="date_H8b">21</div></div></div><a href="https://olneygazettenews.com/$2-million-spreadsheet-gaffe-boosts-rchs-overrun-to-$6-million-p447-90.htm"><span class="heading_H8b" style="display: block;">$2 million spreadsheet gaffe boosts RCHS overrun to $6 million</span></a><div class="body_content_H8b">Mark Allen\nEditor\nThe discovery of a $2 million clerical error pushed bids for renovation of Richland County High School to $6 million above the original estimate of $25.5 million, the board of education was told at a special meeting Nov. 5.\nJon Carroll, of Poettker Construction, said previous spreadsheets failed to include nearly $2 million in fees for construction-management services, and the error was caught Nov. 4. As a result, the total was $31.5 million instead of $29.5 million.\n“That’s very disappointing,” said board member Steve Marrs.\n“It’s extremely disappointing,” Carroll said, adding that board members were “not as disappointed as I am.”\nA “simple formula error” resulted from transferring the wrong number from the budget to the spreadsheet, Carroll said. They had been focused on money-saving revisions, he said, which was why the mistake hadn’t been found.\n“Not one of our prouder moments, Steve,” Carroll said.\n“So now we can’t afford this,” Marrs said.\n“That’s where we’re at right now,” Carroll said, but they had to work to get the cost down. He mentioned discussing with RCHS Principal Chad LeCrone and Superintendent Chris Simpson about what additional funding the board might be comfortable providing.\nAbout $1 million had been trimmed by tweaking the renovation of the T&I wing, Carroll said, and an additional $250,000 might be saved from changes in bids already received. Cuts or changes to materials and finishes would be considered.\n“That’s a lot of changes for 5 million dollars,” said board member Dennis Anderson.\nPresident Jeff Wilson asked what caused the large differences in estimates and bids for mechanical and electrical.\nCarroll said he didn’t think those budgets were right to begin with.\n“Why?” Wilson asked.\nCarroll said they did $4 million in initial value engineering, but did not realize that much savings when bids were received. The estimates were supposed to be conservative, he said, but “the market kind of said otherwise.”\nSome bids were higher than anticipated, Carroll said, but bad numbers were included from how the scope evolved through design such as not being able to reuse ducts. “Some of that scope crept up.”\nWilson asked if BLDD or Poettker did that.\nCarroll said they worked with BLDD on technical systems, and the architects gave Poettker the original scope and a budget prepared before Poettker was involved.\nAs the project went through design-development, they tried to get feedback from each designer on changes to the scope, Carroll said, but didn’t get good information or ask the right questions to track changes. Once drawings were distributed, they realized the project had a larger scope.\nBidders said a lot more work was involved than anticipated, he said. “There was some miscommunication between us and the design team before the bids went out,” Carroll said.\nThe market for construction work was also higher, and the project received less interest than expected, he said.\n“The big question now is how do we save 6 million,” said board member Leon Redman, adding it couldn’t be done by tweaking the design or floor coverings. “It has to be something that’s a fifth of the project,” he said.\nCarroll said Poettker had not been tasked with saving $6 million at that point, but to get the scope the district wanted to achieve, that’s what the market was stating it would cost.\nAnderson said changes would have to be big to get the cost down that much, and tweaking the scope or schedule would not cut it.\nRedman said the whole project needed to be reshaped in some aspects, and the district was committed to part of it already. He asked what the options were.\nCarroll said it depended on how many dollars needed to be saved.\nAnderson asked how much the new theater cost on its own.\nCarroll said he did not remember a total price for the addition.\nWilson noted the addition included the commons area.\nCarroll said the auxiliary gym would be the other new work.\nAnderson asked how much the gym added.\nCarroll said he didn’t know.\n“So you don’t have information for us to make a decision tonight,” Marrs said.\nCarroll said the question was how much more the district was willing to add to the project, and cutting a million was a lot different from $3 million.\nRedman said the board’s previously approved $27.276 million was a good place to start; they had already increased the project by $1.7 million. Somehow, $4.3 million needed to be cut, he said.\nWilson said the $6 million amount over budget included $1 million in contingencies.\nRedman said they would need that and possibly more.\n“Jon, I’m sorry but I gotta say this, the confidence is gone. It’s gone,” Wilson said.\n“We as a board have to come to consensus how much dollars we’re comfortable putting to the project from our own dollars,” Wilson said.\nBoard member Cindy Lockley said they discussed using money from Buildings and Grounds.\nWilson said the district had more sales-tax money than it needed to immediately service bonds, a strong Working Cash fund of $2.8 million that had not been touched for 13-15 years, and about $4 million in Buildings and Grounds. That last fund was built up knowing the high school needed work, he said.\nSimpson said $600,000 of the $1.3 million generated by sales tax was obligated for bond payments, leaving $700,000 that could be applied to the $6 million; the board previously approved an extra $1.7 million, dropping the amount to $4.3 million, and the sales tax money got that to $3.6 million. If they tasked Poettker with finding another million, the total would be $2.6 million with a projected $4.1 million in FY21 in Buildings and Grounds and $2.7 million in Working Cash that could be applied to preserve the project’s overall scope.\nThe district had a window of opportunity to plan a building that would be utilized for 50-70 years, Simpson said. They needed to decide what additional amount they were comfortable contributing.\nThe district’s goal and commitment was to deliver the renovation without impacting property-tax rates, Simpson said. “And none of what I just described” impacts tax rates, he said.\nThe district’s fund balances were accrued to spend money on the high school, he said, adding that using them would not impact the Education Fund.\n“If you’re looking for a recommendation from me, we need to add additional money to the project to get the scope of project we want and accomplish goals for facilities for the next three generations of students,” Simpson said. The question of how much was probably $2.5-$3 million, he said.\nAnderson noted the money was saved for fixing part of the building that was torn down.\nWilson said the gym roof would probably have been the bigger expense, and that was now part of the renovation project.\nSimpson said Sliva Auditorium had probably needed $1.7 million of work.\n“I dunno, it’s starting to look cheaper than new now,” Anderson said.\nBoard member Kelsie Barnes asked Carroll if another $1 million could realistically be cut from the project.\nCarroll said he thought they could get it from $6 million over budget to $5 million with minimal scope changes. Changing flooring and ceilings outside T&I had not yet been considered, he said.\nLockley said it was fine to go cheaper on ceilings and floors because they could be updated in the future, but she didn’t want to cut items in classrooms that teachers needed.\nCarroll said changes in finishes would not change functionality, and some items might be more durable and less expensive. They had been focused on mechanical systems but didn’t realize there was such a large gap to bridge, he said.\nLeCrone said they had just received the numbers that day, and needed time to study projections.\nWilson said he hated to lose the safety net the district’s fund balances had built up, but the money came from taxpayers. “If we’re not putting it into our students, then we need to change our tax levy,” he said.\n“I think we’re gonna get to. I don’t think there’s an option,” Anderson said, adding that they had not started building the main part and had problems with extras.\nLockley said that if all the money were spent on the renovation, the district wouldn’t have it for work on RCES.\nSimpson said he talked with State Rep. Darren Bailey recently about the future of education funding, but couldn’t get State Sen. Dale Righter to return his calls, probably because Righter was not running for re-election.\nWilson asked how much the state owed the district during each fiscal year.\nSimpson said state payments for the Education Fund were kept mostly up to date, but categorical payments lagged for transportation and special education.\nSimpson said Working Cash levied about $140,000 each year, and was up to $2.609 million after not being touched since at least 2002. Operating funds increased from $5.3 million in FY15 to $14.5 million in FY19, he said.\nWilson said the board needed to know what the district’s financial rating would be if fund balances were used.\nThe district had $700,000 of sales-tax revenue more than required to service debt, he said, and could have another $600,000 before the project was completed.\nIn addition to using money from Working Cash, and Buildings and Grounds, the Education Fund could be tapped for items such as furnishings, Wilson said.\n“It’s a healthy fund balance now. I don’t like the thought of invading it,” he said, but they needed to consider all angles to determine how much each fund could be drawn down, and what that would do to the district’s financial profile.\nSimpson said numbers presented at the meeting were rough figures prepared that afternoon, and better totals would be compiled for a variety of scenarios. Furnishings would be an allowable and appropriate use of the Education Fund, he said, because they directly impact classroom structure, similar to buying materials, supplies, and equipment.\nWilson said Education money could buy welders for the ag shop. “Things like that fit. And those are fairly significant items.”\nHe added that he hoped the Education Association would see those dollars as being used to improve the teaching environment.\n“We’ll communicate with the association along the way,” Simpson said.\nRedman asked Carroll how much could be trimmed from the bids without making major changes.\nCarroll said cutting more than $1 million would require significant changes. “Beyond a million, there’s just not enough square-foot dollars out there.”\nAfter reviewing all changes made during value engineering, the board:\nAwarded a $316,000 contract for Masonry to Wagner Masonry;\nAwarded a $660,515 contract for Roofing and Sheet Metal to Geissler Roofing; \nAwarded a $996,240 contract for Aluminum Storefront and Curtain Wall Systems to Illini Glass Solutions, LLC dba Arrow Glass & Mirror.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/$2-million-spreadsheet-gaffe-boosts-rchs-overrun-to-$6-million-p447-90.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="$2 million spreadsheet gaffe boosts RCHS overrun to $6 million" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">OCT</div><div id="date_H8b">11</div></div></div><a href="https://olneygazettenews.com/city-approves-just-in-case-cannabis-tax-p432-164.htm"><span class="heading_H8b" style="display: block;">City approves just-in-case cannabis tax</span></a><div class="body_content_H8b">Mark Allen\nEditor\nOlney City Council approved a 3-percent tax on recreational cannabis at its meeting Sept. 23 after confirming the move was not tantamount to approving a dispensary to locate in the city.\nCity Attorney Bart Zuber presented a model ordinance suggested by Illinois Municipal League. Recreational cannabis will be legal Jan. 1; as the law was written, cities could not apply a tax until Dec. 1, he said, but IML believed that would change.\nThe League advised approving a tax now to get the ordinance certified by the Department of Revenue, said City Treasurer Jane Guinn.\nIf a tax were not approved by Oct. 1, Zuber said, it could not be applied until July 1 or Sept. 1, 2020.\nA dispensary would likely not propose a location for several months, he said. The council could choose not to approve a recreational dispensary, but the state did not allow cities to reject medical dispensaries if the state approved them.\n“Those are two very distinct things,” Zuber said of medical versus recreational.\nThe city could approve fairly strict zoning rules, he said, and recounted what he recently learned in Chicago.\nPatrons enter through a bulletproof breezeway and present identification, then enter a waiting area, Zuber said. All areas were under constant surveillance, and the state police have live access to all surveillance feeds.\nAfter traversing a vestibule, customers another waiting area, with the retail space in still another room, he said. The number of people was limited, and no product was ever allowed on the retail floor, although customers could peruse packaging.\n\nSales representatives enter a secure area akin to a bank vault, Zuber said, then proceed back through many locked areas. “It is really, really strict.”\nAdult-recreational venues were one of the law’s categories, he said. Others include craft growers, infusers, transporters, and cultivation centers.\nThe city could host a company involved solely in transport, Zuber said.\n“It’s an industry that even the experts are saying we’ll take it one step at a time,” he said. “The consensus is Illinois has the most regulated yet counterintuitively most efficient system in the nation,” Zuber said.\nCouncilman John McLaughlin asked for clarification that approving the tax would not mean approving dispensaries.\nZuber said the ordinance meant that if the council approved a dispensary, and one located here – which he said was a “bigger if” – the city would receive up to 3 percent of gross receipts.\nMcLaughlin asked if the 3 percent would be earmarked by the state for some purpose.\nGuinn said it would not, but there were other taxes added for training and other reasons.\nZuber said the state would be collecting that money anyway. “There’s gonna be a lotta tax on all these products.”\nAudience member Bruno Biava asked what was the highest tax the city could apply. Told 3 percent, he said, “Heavens to Murgatroyd. That’s incredible.”\nIn other business:\n• The council declined to amend an ordinance to allow parking on the south side of Elm Street between Kitchell and Camp avenues.\nCity Manager Allen Barker said the request was received “more or less for old-folk parking for businesses in that area.”\nPolice Chief Kevin Paddock said eliminating parking on the north side might be necessary to create more space if parking were allowed on the south side.\nMayor Mark Lambird said the request was to have parking on the south rather than the north.\nMcLaughlin said navigating the road would be tough with parking on north and south.\nLambird said they wanted to eliminate parking on the north side of the road.\n“That’s not what’s presented here,” McLaughlin said.\nLambird said he was stating exactly what the business requested.\nMcLaughlin asked what the difference was between parking on the north or south sides.\nLambird said the north side was divided by entrances, and parking was probably not allowed on the south side originally due to Central School.\nBarker said the south side was currently marked for no parking.\nMcLaughlin said the rest of the street from Camp to Ill. 130 would still be no parking on the south side, and questioned allowing it for one block.\n“How frequently would that be relevant?” Eyer asked of the restaurant/club parking lot being full.\nLambird said he didn’t know but sees cars parked on the north side.\nFehrenbacher said the change would not allow many additional parking spots.\nLambird said someone measured it.\nMcLaughlin said it would probably add two spots because there were only two drives on the north side.\nHenton said people can park on the west side of Kitchell near the school.\n“It was just a request they made as things go along,” Lambird said.\nMcLaughlin said it didn’t make a lot of sense to “chop up the road like that.”\nFehrenbacher said she didn’t think the change would allow many more parking spaces.\n• Barker said Eyer requested information on adding shading to “Olney” when the Industrial Park water tower was repainted. City Engineer Mike Bridges got a quote of $7,000 per side, Barker said.\n“You still want it?” Fehrenbacher asked.\n“No, thank you. We’re good,” Eyer said.\n• The council approved selling or recycling 47 bicycles held by Olney Police Department.\n“Where did we come across 47 bicycles?” McLaughlin asked.\nPaddock said the department accumulated 50 to 100 a year.\nBarker said bicycles are just found laying around.\nMcLaughlin asked how that was advertised to someone who had a bike stolen.\n“If you call the police department, we can tell you,” Paddock said.\nBarker added that if someone filed an incident report, the department could contact them.\nPaddock said they used to repair bicycles and give them to children, but the bikes were frequently ridden off and dumped somewhere, and the Street Department would pick them up again.(Votes unanimous unless indicated. Council members include Mayor Mark Lambird, Greg Eyer, Morgan Fehrenbacher, Belinda Henton, and John McLaughlin.)</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/city-approves-just-in-case-cannabis-tax-p432-164.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="City approves just-in-case cannabis tax" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">OCT</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/fred-kuenstler, 83-p442-165.htm"><span class="heading_H8b" style="display: block;">Fred Kuenstler, 83</span></a><div class="body_content_H8b">Fred Kuenstler, 83, of Olney, died Thursday, October 10, 2019, at Lavender Ridge in Olney.\nMass of Christian Burial was held Oct. 15 at te St. Joseph Catholic Church in Olney. Burial was in St. Joseph Catholic Cemetery.\nFred was born October 23, 1935, in Richland County, the son of Henry and Georgiana (Rudolphi) Kuenstler. Fred married Shirley (Shryock) on December 28, 1961, at St. Joseph Catholic Church in Olney. She survives.\nFred was president of the board of directors of Prairie Farms for more than 20 years, and he owned and operated Domino K Dairy. He was a Parish Council Trustee, and he was on the St. Joseph School Board. Fred was a Fourth Degree member of Knights of Columbus. He was also part of the Clay City Class of 1952, and a member of St. Joseph Catholic Church. Fred’s first priority was always his wife. Beyond her, his life revolved around his faith, his farm, and his family.\nFred is survived by his wife of 58 years, Shirley Kuenstler, of Olney; son, John Kuenstler and wife Jill, of Los Angeles; daughter, Kerry Kuenstler, of Arlington, Texas; grandchildren, Daisy and Luke Kuenstler, of Los Angeles, and Justin and Jacob Constantin, of Arlington, Texas; sister, Karen (Tom) Zuber, of Claremont; brothers, Jim (Peg) Kuenstler, Richard (Jeanette) Kuenstler, Dan (MaryAnn) Kuenstler, and Bill (Rita) Kuenstler; numerous nieces and nephews; and beloved brother-in-law, Don Dallmier.\nHe was preceded in death by his parents; infant son, Frederick Kuenstler; and sisters, Ruth Bene and husband John, LouAnn Dallmier, June McGeehon and husband Bill, and Norma Eugenia.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/fred-kuenstler, 83-p442-165.htm"><img u="image" src="https://olneygazettenews.com/10-17-2019-2-43-21-PM-9605309.jpg" alt="Fred Kuenstler, 83" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="https://olneygazettenews.com/10-17-2019-2-43-21-PM-9605309.jpg" /></div></div><div><div class="sing-slide_H8b"><div class="head-body-container_H8b"><div class="pageissuedate layout_pageissuedate"><div id="times_H8b"><span class="binds"></span><div id="month_H8b">OCT</div><div id="date_H8b">10</div></div></div><a href="https://olneygazettenews.com/daniel-f-gaddy,-75-p437-165.htm"><span class="heading_H8b" style="display: block;">Daniel F. Gaddy, 75</span></a><div class="body_content_H8b">Daniel F. Gaddy, 75\nDaniel F. Gaddy, 75, of Olney, died Monday, October 7, 2019, at Helia Healthcare in Olney.\nCremation rites were accorded. No formal services were planned.\nDaniel was born November 10, 1943, in Olney, the son of Homer and Marie (Cochran) Gaddy. He married Camille Knackmuhs on August 25, 1968, in Olney. She survives.\nHe worked as a factory worker for several years. He served in the United States Air Force, and attended Free Methodist Church in Olney. Daniel enjoyed listening to music and taking walks, and was in a bowling league in Olney. He will be sadly missed by his family, friends, and everyone who knew him.\nDaniel is survived by his wife, Camille Gaddy, of Olney; three sons, Daniel Thomas Gaddy, of Olney, Homer Roy Gaddy, (Pat) of Olney, Ronald Dale Gaddy, of Olney; brother, Tom Gaddy, of Olney; and sister, Helen Fisk, of Olney.\nHe was preceded in death by his parents, Homer and Marie Gaddy, and brother, Dale Gaddy.</div></div><div class="img_cont_H8b"><a href="https://olneygazettenews.com/daniel-f-gaddy,-75-p437-165.htm"><img u="image" src="/clients/olneygazettenews/Blank_logo.jpg" alt="Daniel F. Gaddy, 75" class="article-img_H8b" style="display: block;"/></a></div><img u="thumb" src="/clients/olneygazettenews/Blank_logo.jpg" /></div></div></div>	<div u="navigator" class="jssorb21_H8b"><div u="prototype" style="POSITION: absolute; width: 35px; height: 35px; text-align:center; line-height:19px; color:White; font-size:12px;"></div></div></span></div><script type="text/javascript">jQuery(document).ready(function() {jQuery(\'#newsslider\').accessNews({});});<\/script></div>');DisplayHighlight('Highlight8');}

